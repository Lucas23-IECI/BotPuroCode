generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum EstadoPresencia {
  PENDIENTE
  SIN_WEB
  SOLO_RRSS
  LINK_EXTERNO
  WEB_BASICA
  WEB_MEDIA
  WEB_BUENA
}

enum NivelOportunidad {
  NO_EVALUADO
  ALTA
  MEDIA_ALTA
  MEDIA
  BAJA
  NO_PRIORITARIO
}

enum EstadoContacto {
  NO_CONTACTADO
  CONTACTADO
  PROPUESTA_ENVIADA
  NEGOCIANDO
  CERRADO_GANADO
  CERRADO_PERDIDO
  CERRADO_NO_EXISTE
}

enum TipoContacto {
  LLAMADA
  EMAIL
  WHATSAPP
  INSTAGRAM_DM
  VISITA
  OTRO
}

enum ResultadoContacto {
  INTERESADO
  NO_INTERESADO
  NO_CONTESTA
  SEGUIMIENTO
  PROPUESTA_ENVIADA
  CERRADO
}

enum CalidadDatos {
  COMPLETO
  PARCIAL
  MINIMO
  SIN_CONTACTO
}

enum EstadoGoogle {
  ACTIVO
  CERRADO_PERMANENTE
  CERRADO_TEMPORAL
  NO_ENCONTRADO
  VERIFICAR
}

enum Rol {
  ADMIN
  VENDEDOR
}

enum TipoPlantilla {
  WHATSAPP
  EMAIL
}

enum TipoNotificacion {
  SEGUIMIENTO_PENDIENTE
  LEAD_CALIENTE
  TAREA_ASIGNADA
  GENERAL
}

// ─── Models ──────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email    String @unique
  nombre   String
  password String // bcrypt hash
  rol      Rol    @default(VENDEDOR)
  activo   Boolean @default(true)

  // Perfil extendido
  cargo            String?
  bio              String?
  telefono         String?
  avatarBase64     String?  @db.Text
  mustChangePassword Boolean @default(false)
  lastLoginAt      DateTime?

  negociosAsignados Negocio[]      @relation("AsignadoA")
  contactosCreados  Contacto[]     @relation("ContactoCreadoPor")
  propuestas        Propuesta[]
  notificaciones    Notificacion[]
  activityLogs      ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  accion    String   // LOGIN, CREATE_NEGOCIO, UPDATE_NEGOCIO, etc.
  entidad   String?  // Negocio, Contacto, Propuesta, etc.
  entidadId String?
  detalle   String?
  metadata  String?  // JSON string for extra data

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([accion])
}

model Negocio {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identificación
  nombre   String
  rubro    String
  subrubro String?

  // Ubicación
  comuna    String
  ciudad    String?
  region    String?
  direccion String?
  lat       Float?
  lng       Float?

  // Contacto público del negocio
  telefono String?
  email    String?
  whatsapp String?

  // Presencia digital
  sitioWeb      String?
  instagram     String?
  facebook      String?
  tiktok        String?
  linkExterno   String?
  tipoLinkExt   String?

  // Google Maps / Places
  gmapsRating    Float?
  gmapsReviews   Int?
  googlePlaceId  String?
  horarios       String?   // JSON string de horarios
  estadoGoogle   EstadoGoogle?
  fotosUrl       String[]

  // RRSS métricas
  igFollowers  Int?
  igLastPost   DateTime?
  fbFollowers  Int?
  fbLastPost   DateTime?

  // Clasificación
  estadoPresencia  EstadoPresencia  @default(PENDIENTE)
  score            Int              @default(0)
  nivelOportunidad NivelOportunidad @default(NO_EVALUADO)
  razonesScore     String[]
  calidadDatos     CalidadDatos     @default(MINIMO)

  // CRM
  estadoContacto       EstadoContacto @default(NO_CONTACTADO)
  notas                String?
  fechaUltimoContacto  DateTime?
  proximoSeguimiento   DateTime?

  // Asignación
  asignadoAId String?
  asignadoA   User?   @relation("AsignadoA", fields: [asignadoAId], references: [id])

  // Meta
  fuenteDescubrimiento String @default("manual")

  // Relations
  analisis   Analisis[]
  contactos  Contacto[]
  propuestas Propuesta[]

  @@index([rubro])
  @@index([comuna])
  @@index([score(sort: Desc)])
  @@index([estadoContacto])
  @@index([estadoPresencia])
  @@index([calidadDatos])
  @@index([asignadoAId])
}

model Analisis {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  negocioId String
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  // Presencia
  dominioExiste   Boolean?
  dominioResponde Boolean?
  httpStatus      Int?
  redirectUrl     String?

  // Técnico
  tieneSSL          Boolean?
  esResponsive      Boolean?
  tecnologia        String?
  plantillaGenerica Boolean?

  // Contenido
  tieneFormulario      Boolean?
  tieneCTA             Boolean?
  tieneWhatsappWidget  Boolean?
  tieneFavicon         Boolean?

  // SEO
  tieneTitle       Boolean?
  titleText        String?
  tieneMetaDesc    Boolean?
  metaDescText     String?
  tieneH1          Boolean?
  tieneSitemap     Boolean?
  tieneRobotsTxt   Boolean?

  // Performance (PageSpeed)
  performanceScore Int?
  lcpMs            Float?
  fcpMs            Float?
  cls              Float?

  // Errores
  errores String[]

  @@index([negocioId])
}

model Contacto {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  negocioId String
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  tipo      TipoContacto
  resultado ResultadoContacto?
  notas     String?

  // Quién registró el contacto
  creadoPorId String?
  creadoPor   User?   @relation("ContactoCreadoPor", fields: [creadoPorId], references: [id])

  @@index([negocioId])
}

model Plantilla {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nombre    String
  tipo      TipoPlantilla
  asunto    String?          // solo EMAIL
  cuerpo    String           // con variables {nombre}, {rubro}, {comuna}, etc.
  categoria String?          // "primer_contacto", "seguimiento", "propuesta", etc.
  activa    Boolean          @default(true)
}

model Propuesta {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  negocioId String
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  creadoPorId String
  creadoPor   User   @relation(fields: [creadoPorId], references: [id])

  tipoServicio   String   // "landing", "corporativa", "ecommerce"
  precioBase     Int      // CLP
  descuento      Int      @default(0) // porcentaje
  precioFinal    Int
  diagnostico    String   // texto del diagnóstico
  solucion       String   // solución propuesta
  pdfUrl         String?  // URL del PDF generado
  estado         String   @default("borrador") // borrador, enviada, aceptada, rechazada

  @@index([negocioId])
}

model Notificacion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tipo      TipoNotificacion
  titulo    String
  mensaje   String
  leida     Boolean @default(false)
  metadata  String? // JSON con data extra (negocioId, etc.)

  @@index([userId, leida])
}

model Automatizacion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nombre    String
  activa    Boolean @default(true)

  // Trigger: CAMBIO_ESTADO, SCORE_MAYOR, SCORE_MENOR, NUEVO_LEAD
  trigger   String

  // Condición (JSON): { "estadoContactoAnterior": "NO_CONTACTADO", "estadoContactoNuevo": "CONTACTADO" }
  // o { "scoreUmbral": 70 } o {} para NUEVO_LEAD
  condicion String  @default("{}")

  // Acción: CREAR_NOTIFICACION, CAMBIAR_ESTADO, ENVIAR_TEMPLATE
  accion    String

  // Config acción (JSON): { "titulo": "...", "mensaje": "..." }
  // o { "nuevoEstado": "CONTACTADO" } o { "plantillaId": "...", "tipo": "WHATSAPP" }
  accionConfig String @default("{}")
}
